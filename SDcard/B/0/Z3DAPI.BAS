100 REM ---- Ambient & Parallel Light ----
110 CF= 8.0:GOSUB 1000:OUT &H79,CH:OUT &H78,CL
120 CF= 8.0:GOSUB 1000:OUT &H7B,CH:OUT &H7A,CL
130 CF=-8.0:GOSUB 1000:OUT &H7D,CH:OUT &H7C,CL
140 CF= 1.0:GOSUB 1000:OUT &H7F,CH:OUT &H7E,CL
150 CF= 0.5:OUT &H62,CF*255:OUT &H63,0
