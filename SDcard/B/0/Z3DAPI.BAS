170 ML=INP(&H64):OUT &H6E,0:OUT &H64,0
180 REM ---- Push Perspective Trans Matrix ----
190 CF=  1.0:GOSUB 1000:OUT &H79,CH:OUT &H78,CL
200 CF=100.0:GOSUB 1000:OUT &H7B,CH:OUT &H7A,CL
