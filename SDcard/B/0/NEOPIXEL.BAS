100 S=1:PI=3.14159
110 FOR C=0 TO 999
120 H=C*0.001
130 V=0.75+COS(6*PI*H)*0.25
140 GOSUB 200
150 OUT &H20,&HFF*R:OUT &H21,&HFF*G
160 OUT &H22,&HFF*B:OUT &H23,&HC0
170 NEXT C:GOTO 110
200 A=H*6:T=1-S:I=INT(A):F=A-I:R=V:G=V:B=V
210 ON I+1 GOTO 220,230,240,250,260,270
220 G=G*(T+S*F):B=B*T:RETURN
230 R=R*(1-S*F):B=B*T:RETURN
240 B=B*(T+S*F):R=R*T:RETURN
250 G=G*(1-S*F):R=R*T:RETURN
260 R=R*(T+S*F):G=G*T:RETURN
270 B=B*(1-S*F):G=G*T:RETURN
