
#/==============================================================================/#
#/		Z80 Single Board Computer "PC-84C0xx 20MHz" HEX to ROM Converter		/#
#/				Implemented by Shisuibi --Grand Master Sorcerian--				/#
#/==============================================================================/#


#/==============================================================================/#
BINBCC	=	bcc32
BINDEL	=	del
#/------------------------------------------------------------------------------/#
OBJOPT	=	-c
EXEOPT	=
RESOPT	=	-I"C:\Program Files (x86)\BCC\Include"
LIBOPT	=	-L"C:\Program Files (x86)\BCC\Lib"
DELOPT	=	/Q
#/------------------------------------------------------------------------------/#
SRCLST	=	Hex2Rom.c\

TARGET	=	Hex2Rom
#/==============================================================================/#


#/==============================================================================/#
$(TARGET).exe:	$(SRCLST:.c=.obj)
	$(BINBCC) $(LIBOPT) $(EXEOPT) -e$@ $(SRCLST:.c=.obj)
#/------------------------------------------------------------------------------/#
.c.obj:
	$(BINBCC) $(RESOPT) $(OBJOPT) -o$@ $<
#/------------------------------------------------------------------------------/#
$(SRCLST:.c=.obj):	$(SRCLST:.c=.h)
#/------------------------------------------------------------------------------/#
clean:
	$(BINDEL) $(DELOPT) $(SRCLST:.c=.obj) $(TARGET).exe $(TARGET).tds
#/==============================================================================/#

