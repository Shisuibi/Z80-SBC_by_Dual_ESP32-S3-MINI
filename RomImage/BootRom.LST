  02DC                	CpmMakeMsgTop:
  02DC  0D0A          		DB		CR, LF
  02DE  3C3C3C3C204350		DB		"<<<< CP/M Disk Image Manager >>>>", CR, LF
  0301  0D0A          		DB		CR, LF
  0303                	CpmMakeMsgNum1:
  0303  312E204D532D44		DB		"1. MS-DOS FAT -> CP/M Image", CR, LF
  0320                	CpmMakeMsgNum2:
