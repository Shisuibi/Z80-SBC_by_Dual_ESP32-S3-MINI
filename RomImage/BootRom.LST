  026F                	CpmBiosMsgTop:
  026F  0D0A          		DB		CR, LF
  0271  43502F4D20322E		DB		"CP/M 2.2 Copyright (C) 1979 Digital Research", CR, LF
  029F  4E617473756D69		DB		"Natsumi Gen4 CP/M 2.2 BIOS (C) 2026 Shisuibi", CR, LF
