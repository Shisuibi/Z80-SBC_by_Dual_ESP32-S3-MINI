  0045  D320          		OUT		(PortAnyNum00), A
  0047  D321          		OUT		(PortAnyNum01), A
  0049  D322          		OUT		(PortAnyNum02), A
                      	
  004B  3E15          		LD		A, InitAnyNum03
  004D  D323          		OUT		(PortAnyNum03), A
                      	;/------------------------------------------------------------------------------/;
  004F                	ColdBootDisp:
  004F  218000        		LD		HL, ColdBootMsgTop
  0052  066A          		LD		B, ColdBootMsgBtm - ColdBootMsgTop
