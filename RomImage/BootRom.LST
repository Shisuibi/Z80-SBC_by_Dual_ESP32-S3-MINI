                      	;/------------------------------------------------------------------------------/;
  0020                	ColdBootBios:
  0020  2100F2        		LD		HL, CpmBiosBaseAdrs
  0023  1E0E          		LD		E, 00H - CpmBiosBaseAdrs / 0100H
                      	
  0025  45            		LD		B, L
  0026  4D            		LD		C, L
                      	
  0027  7C            		LD		A, H
  0028  D303          		OUT		(PortBiosParamH), A
                      	
  002A  7D            		LD		A, L
  002B  D302          		OUT		(PortBiosParamL), A
                      	;/------------------------------------------------------------------------------/;
  002D                	ColdBootRomImage:
  002D  EDB2          		INIR
  002F  1D            		DEC		E
  0030  20FB          		JR		NZ, ColdBootRomImage
                      	
  0032  C9            		RET
                      	;/==============================================================================/;
                      	
                      	
                      	;/==============================================================================/;
  0038                	ORG		0038H
                      	;/------------------------------------------------------------------------------/;
  0038                	CpuInterrupt:
  0038  F5            		PUSH	AF
