  03B4  FE00          		CP		0
  03B6  280F          		JR		Z, CpmBiosExit
                      	
  03B8  21CDF3        		LD		HL, CpmBiosBaseAdrs + CpmBiosSubTop - CpmBiosEntry
  03BB  1108DC        		LD		DE, CpmCcprBaseAdrs + 0008H
  03BE  010F00        		LD		BC, CpmBiosSubBtm - CpmBiosSubTop
                      	
  03C1  79            		LD		A, C
  03C2  3207DC        		LD		(CpmCcprBaseAdrs + 0007H), A
  03C5  EDB0          		LDIR
                      	;/------------------------------------------------------------------------------/;
  03C7                	CpmBiosExit:
