                      	;/------------------------------------------------------------------------------/;
  0010                	ORG		0010H
                      	;/------------------------------------------------------------------------------/;
  0010                	TransRecv:
  0010  DB31          		IN		A, (PortUartData)
  0012  FE00          		CP		NUL
  0014  28FA          		JR		Z, TransRecv
                      	
  0016  C9            		RET
                      	;/------------------------------------------------------------------------------/;
  0018                	ORG		0018H
                      	;/------------------------------------------------------------------------------/;
  0018                	TransCheck:
