  033D  0D0A          		DB		CR, LF
  033F  57686963682064		DB		"Which do you want (1 or 2)? "
  035B                	CpmMakeMsgAtoP:
  035B  0D0A          		DB		CR, LF
  035D  57686963682064		DB		"Which drive is it (A to P / All:Z)? "
  0381                	CpmMakeMsgYorN:
