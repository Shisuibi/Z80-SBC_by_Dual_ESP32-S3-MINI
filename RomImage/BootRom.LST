  0203  F9            		LD		SP, HL
                      	
  0204  0E31          		LD		C, PortUartData
                      	;/------------------------------------------------------------------------------/;
  0206                	CpmMakeDisp1or2:
  0206  21DCF3        		LD		HL, CpmBiosBaseAdrs + CpmMakeMsgTop - CpmBiosEntry
  0209  067F          		LD		B, CpmMakeMsgAtoP - CpmMakeMsgTop
  020B  EDB3          		OTIR
                      	;/------------------------------------------------------------------------------/;
  020D                	CpmMakeMove1or2:
  020D  D7            		RST		TransRecv
  020E  57            		LD		D, A
                      	
  020F  FE32          		CP		'2'
  0211  2810          		JR		Z, CpmMakeDispNum2
                      	
  0213  FE31          		CP		'1'
  0215  20F6          		JR		NZ, CpmMakeMove1or2
                      	;/------------------------------------------------------------------------------/;
  0217                	CpmMakeDispNum1:
  0217  CD5DF3        		CALL	CpmBiosBaseAdrs + CpmMakeDiskMove - CpmBiosEntry
                      	
  021A  2103F4        		LD		HL, CpmBiosBaseAdrs + CpmMakeMsgNum1 - CpmBiosEntry
  021D  061D          		LD		B, CpmMakeMsgNum2 - CpmMakeMsgNum1
  021F  EDB3          		OTIR
                      	
  0221  180A          		JR		CpmMakeDispAtoP
                      	;/------------------------------------------------------------------------------/;
  0223                	CpmMakeDispNum2:
  0223  CD5DF3        		CALL	CpmBiosBaseAdrs + CpmMakeDiskMove - CpmBiosEntry
                      	
  0226  2120F4        		LD		HL, CpmBiosBaseAdrs + CpmMakeMsgNum2 - CpmBiosEntry
  0229  061D          		LD		B, CpmMakeMsg1or2 - CpmMakeMsgNum2
  022B  EDB3          		OTIR
                      	;/------------------------------------------------------------------------------/;
  022D                	CpmMakeDispAtoP:
  022D  215BF4        		LD		HL, CpmBiosBaseAdrs + CpmMakeMsgAtoP - CpmBiosEntry
  0230  0626          		LD		B, CpmMakeMsgYorN - CpmMakeMsgAtoP
  0232  EDB3          		OTIR
                      	;/------------------------------------------------------------------------------/;
  0234                	CpmMakeMoveAtoP:
  0234  D7            		RST		TransRecv
  0235  E6DF          		AND		UpperLowerCase
  0237  5F            		LD		E, A
                      	
  0238  FE41          		CP		'A'
  023A  38F8          		JR		C, CpmMakeMoveAtoP
                      	
  023C  FE51          		CP		'P' + 1
  023E  3804          		JR		C, CpmMakeDispYorN
                      	
  0240  FE5A          		CP		'Z'
  0242  20F0          		JR		NZ, CpmMakeMoveAtoP
                      	;/------------------------------------------------------------------------------/;
  0244                	CpmMakeDispYorN:
  0244  CD5DF3        		CALL	CpmBiosBaseAdrs + CpmMakeDiskMove - CpmBiosEntry
                      	
  0247  2181F4        		LD		HL, CpmBiosBaseAdrs + CpmMakeMsgYorN - CpmBiosEntry
  024A  0617          		LD		B, CpmMakeMsgBtm - CpmMakeMsgYorN
  024C  EDB3          		OTIR
                      	;/------------------------------------------------------------------------------/;
  024E                	CpmMakeMoveYorN:
  024E  D7            		RST		TransRecv
  024F  E6DF          		AND		UpperLowerCase
                      	
  0251  FE59          		CP		'Y'
  0253  2810          		JR		Z, CpmMakeDiskExit
                      	
  0255  FE4E          		CP		'N'
  0257  20F5          		JR		NZ, CpmMakeMoveYorN
                      	
  0259  21C7F4        		LD		HL, CpmBiosBaseAdrs + CpmBiosExit - CpmBiosEntry
  025C  E5            		PUSH	HL
                      	;/------------------------------------------------------------------------------/;
  025D                	CpmMakeDiskMove:
  025D  CF            		RST		TransSend
                      	
  025E  3E0D          		LD		A, CR
  0260  CF            		RST		TransSend
                      	
  0261  3E0A          		LD		A, LF
  0263  CF            		RST		TransSend
                      	
  0264  C9            		RET
                      	;/------------------------------------------------------------------------------/;
  0265                	CpmMakeDiskExit:
  0265  CD5DF3        		CALL	CpmBiosBaseAdrs + CpmMakeDiskMove - CpmBiosEntry
                      	
  0268  7A            		LD		A, D
  0269  D303          		OUT		(PortBiosParamH), A
                      	
  026B  7B            		LD		A, E
  026C  D300          		OUT		(PortMakeDisk), A
                      	
  026E  76            		HALT												;/	System Reset
                      	;/==============================================================================/;
                      	
                      	
